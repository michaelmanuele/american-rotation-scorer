{
  "expo": {
    "name": "American Rotation Scorer",
    "slug": "american-rotation-scorer",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "arscorer",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0B3A52"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.michaelmanuele.arscorer"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B3A52"
      },
      "package": "com.michaelmanuele.arscorer"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
