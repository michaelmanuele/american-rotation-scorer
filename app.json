{
  "expo": {
    "name": "American Rotation Scorer",
    "slug": "american-rotation-scorer",
    "version": "0.2.1",
    "orientation": "default",
    "scheme": "arscorer",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B3A52"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.michaelmanuele.arscorer",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B3A52"
      },
      "package": "com.michaelmanuele.arscorer"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "343155fe-610c-4ddf-b8f4-c2726bbde2b3"
      },
      "oauthBaseUrl": "https://arscorer-oauth.mikeonthefelt.workers.dev"
    }
  }
}
